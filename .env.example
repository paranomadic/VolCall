# Hosted PostgreSQL. Must match prisma/schema.prisma (Vercel Neon Storage uses this name).
neon_storage_POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Comma-separated emails allowed to open /admin (alternative: set User.isAdmin in DB)
ADMIN_EMAILS="you@example.com"

# Public URL of the app (no trailing slash). On Vercel use https://your-project.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (Resend) — optional; without it, verification uses demo token + /verify-email ---
RESEND_API_KEY=""
# Must be a verified sender in Resend, e.g. onboarding@yourdomain.com
RESEND_FROM_EMAIL="VolCall <onboarding@example.com>"

# --- Twilio Verify — optional; without it, phone OTP accepts 000000 only ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# --- Lemon Squeezy — primary hosted checkout when all vars below are set (overrides Stripe) ---
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
# Variant IDs from Products → variant in Lemon Squeezy (monthly vs annual products)
LEMONSQUEEZY_VARIANT_MONTHLY=""
LEMONSQUEEZY_VARIANT_ANNUAL=""
# Webhook signing secret (Settings → Webhooks); endpoint: /api/lemonsqueezy/webhook
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Set to "true" for Lemon test mode checkouts
# LEMONSQUEEZY_TEST_MODE="false"

# --- Stripe — optional fallback when Lemon Squeezy is not fully configured ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_ANNUAL=""
# Used to sign webhook payloads in dev; optional if only using checkout-return
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Alert engine (workers/alert-engine.ts) ---
# Optional Redis for 24h per-user/asset cooldown keys (matches PRD intent)
REDIS_URL=""
# If "true", logs breaches but does not place voice calls
ALERT_ENGINE_DRY_RUN="true"
# Vapi — primary IVR/voice for alerts when all three are set
VAPI_API_KEY=""
VAPI_ASSISTANT_ID=""
VAPI_PHONE_NUMBER_ID=""
# Set to "true" if your Vapi assistant defines variables asset, dvol, band
# VAPI_USE_VARIABLE_VALUES="false"
# Twilio voice — fallback when Vapi fails or is not configured (only when DRY_RUN is not true)
TWILIO_FROM_NUMBER=""
